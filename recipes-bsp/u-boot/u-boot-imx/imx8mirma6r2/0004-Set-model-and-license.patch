From c31ba1998cedab784e63a67da47a51d39cbbe2ec Mon Sep 17 00:00:00 2001
From: Michael Glembotzki <Michael.Glembotzki@iris-sensing.com>
Date: Fri, 11 Mar 2022 09:32:10 +0100
Subject: [PATCH 04/15] Set model and license

Customize base configurations like model name and license.

Signed-off-by: Michael Glembotzki <Michael.Glembotzki@iris-sensing.com>
---
 arch/arm/dts/imx8mp-irma6r2.dts | 11 ++++++-----
 1 file changed, 6 insertions(+), 5 deletions(-)

diff --git a/arch/arm/dts/imx8mp-irma6r2.dts b/arch/arm/dts/imx8mp-irma6r2.dts
index 05bee3ad81..63a52564c5 100644
--- a/arch/arm/dts/imx8mp-irma6r2.dts
+++ b/arch/arm/dts/imx8mp-irma6r2.dts
@@ -1,7 +1,8 @@
-// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
-/*
- * Copyright 2019 NXP
- */
+// SPDX-License-Identifier: GPL-2.0+
+ /*
+  * Copyright 2022 iris GmbH
+  * Copyright 2019 NXP
+  */
 
 /dts-v1/;
 
@@ -9,7 +10,7 @@
 #include "imx8mp.dtsi"
 
 / {
-	model = "NXP i.MX8MPlus LPDDR4 EVK board";
+	model = "IRMA6 Release2 i.MX8MPlus DDR4 board";
 	compatible = "fsl,imx8mp-evk", "fsl,imx8mp";
 
 	chosen {
