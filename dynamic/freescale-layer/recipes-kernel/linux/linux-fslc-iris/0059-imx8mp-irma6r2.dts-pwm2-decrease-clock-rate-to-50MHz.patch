From cea063148fd87ebb8cba7fec52b3eafa50e4b7eb Mon Sep 17 00:00:00 2001
From: Ian Dannapel <ian.dannapel@iris-sensing.com>
Date: Mon, 4 May 2026 12:54:06 +0000
Subject: [PATCH] imx8mp-irma6r2.dts: pwm2: decrease clock rate to 50MHz

- Acording to https://lore.kernel.org/all/20250218-imx8m-clk-v4-6-b7697dc2dcd0@pengutronix.de/
  the pwm2 max clock rate is 66MHz (IMX8MP_CLK_PWM2)
- 66MHz cannot be precisely converted to 25MHz required by "clk_serializer"

Signed-off-by: Ian Dannapel <ian.dannapel@iris-sensing.com>
---
 arch/arm64/boot/dts/freescale/imx8mp-irma6r2.dts | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/freescale/imx8mp-irma6r2.dts b/arch/arm64/boot/dts/freescale/imx8mp-irma6r2.dts
index e22111131aa7..7d6e88366ee1 100644
--- a/arch/arm64/boot/dts/freescale/imx8mp-irma6r2.dts
+++ b/arch/arm64/boot/dts/freescale/imx8mp-irma6r2.dts
@@ -97,7 +97,7 @@ &pwm2 {
 	pinctrl-0 = <&pinctrl_pwm2>;
 	assigned-clocks = <&clk IMX8MP_CLK_PWM2>;
 	assigned-clock-parents = <&clk IMX8MP_SYS_PLL3_OUT>;
-	assigned-clock-rates = <600000000>;
+	assigned-clock-rates = <50000000>;
 	status = "okay";
 };
 
-- 
2.44.4

