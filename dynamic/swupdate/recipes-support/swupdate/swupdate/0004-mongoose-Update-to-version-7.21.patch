+                sig[1], sig[2], sig[3]));
+    MG_VERBOSE(("RSA signature last 4 bytes: %02x %02x %02x %02x",
+                sig[tls->rsa.n.len - 4], sig[tls->rsa.n.len - 3],
+                sig[tls->rsa.n.len - 2], sig[tls->rsa.n.len - 1]));
+  }
