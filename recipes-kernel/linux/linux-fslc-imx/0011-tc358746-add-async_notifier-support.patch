From 3162f5c3591a2e9a401981e9e36d9a180548e99e Mon Sep 17 00:00:00 2001
From: Rouven Czerwinski <r.czerwinski@pengutronix.de>
Date: Wed, 17 Nov 2021 15:36:54 +0100
Subject: [PATCH 11/25] tc358746: add async_notifier support

To create the link from the source to the sink from the bridge side.
Upstream uses a much neater v4l2_create_fwnode_links_to_pad(sd, sink),
but we don't have this luxory in 5.4.

Signed-off-by: Rouven Czerwinski <r.czerwinski@pengutronix.de>
Signed-off-by: ian.dannapel <ian.dannapel@iris-sensing.com>
---
 drivers/media/i2c/tc358746.c | 87 ++++++++++++++++++++++++------------
 1 file changed, 59 insertions(+), 28 deletions(-)

diff --git a/drivers/media/i2c/tc358746.c b/drivers/media/i2c/tc358746.c
index 8a871c002d50..351a079cc7ed 100644
--- a/drivers/media/i2c/tc358746.c
+++ b/drivers/media/i2c/tc358746.c
@@ -98,6 +98,7 @@ struct tc358746_state {
 	 * Generic
 	 */
 	struct media_pad pads[2];
+	struct v4l2_async_notifier notifier;
 	struct mutex confctl_mutex;
 	struct v4l2_mbus_framefmt fmt;
 	struct v4l2_ctrl_handler hdl;
@@ -1657,43 +1658,73 @@ static int tc358746_probe_fw(struct tc358746_state *state)
 	return ret;
 }
 
-static int tc358746_parse_endpoint(struct device *dev,
-				   struct v4l2_fwnode_endpoint *vep,
-				   struct v4l2_async_subdev *asd)
+static int tc358746_notify_bound(struct v4l2_async_notifier *notifier,
+			     struct v4l2_subdev *sd,
+			     struct v4l2_async_subdev *asd)
 {
-	struct v4l2_subdev *sd = dev_get_drvdata(dev);
-	struct tc358746_state *state = to_state(sd);
+	struct tc358746_state *state =
+		container_of(notifier, struct tc358746_state, notifier);
+	struct media_entity *sink_ent = &state->sd.entity;
+	struct media_entity *source_ent = &sd->entity;
 
-	if (!fwnode_device_is_available(asd->match.fwnode)) {
-		v4l2_err(sd, "remote is not available\n");
-		return -ENOTCONN;
-	}
-	
-	v4l2_info(sd, "FW Node Port: %d\n", vep->base.port);
-	v4l2_info(sd, "FW Node ID: %d\n", vep->base.id);
-	v4l2_info(sd, "Bus type: %d\n", vep->bus_type);
-	v4l2_info(sd, "Link freqs: %d\n", vep->nr_of_link_frequencies);
+	return media_create_pad_link(source_ent, 0, sink_ent, 0, 0);
+}
+
+static const struct v4l2_async_notifier_operations tc358746_notify_ops = {
+	.bound = tc358746_notify_bound,
+};
 
-	v4l2_info(sd, "state->csi_dir(%d) == TC358746_CSI_TX(%d)\n", state->csi_dir, TC358746_CSI_TX);
-	v4l2_info(sd, "vep->bus_type(%d) =! V4L2_MBUS_PARALLEL(%d)\n", vep->bus_type, V4L2_MBUS_PARALLEL);
+static int tc358746_async_register(struct tc358746_state *state)
+{
+	struct v4l2_fwnode_endpoint vep = {
+		.bus_type = V4L2_MBUS_PARALLEL,
+	};
+	struct v4l2_async_subdev *asd = NULL;
+	struct fwnode_handle *ep;
+	int ret;
 
-	if (state->csi_dir == TC358746_CSI_TX &&
-	    vep->bus_type != V4L2_MBUS_PARALLEL) {
-		v4l2_err(sd, "invalid bus type, must be PARALLEL\n");
+	v4l2_async_notifier_init(&state->notifier);
+
+	ep = fwnode_graph_get_endpoint_by_id(dev_fwnode(state->sd.dev), 0, 0, 0);
+	if (!ep)
 		return -ENOTCONN;
+
+	ret = v4l2_fwnode_endpoint_parse(ep, &vep);
+	if (ret)
+		goto err;
+
+	asd = kzalloc(sizeof(*asd), GFP_KERNEL);
+	if (!asd) {
+		ret = -ENOMEM;
+		goto err;
 	}
 
-	return 0;
-};
+	ret = v4l2_async_notifier_add_fwnode_remote_subdev(&state->notifier, ep, asd);
+	if (ret)
+		goto err;
 
-static int tc358746_async_register(struct v4l2_subdev *sd)
-{
-	unsigned int port = 0;
+	fwnode_handle_put(ep);
 
-	return v4l2_async_register_fwnode_subdev(
-		sd, sizeof(struct v4l2_async_subdev), &port, 1,
-		tc358746_parse_endpoint);
+	state->notifier.ops = &tc358746_notify_ops;
 
+	ret = v4l2_async_subdev_notifier_register(&state->sd, &state->notifier);
+	if (ret)
+		goto err;
+
+	ret = v4l2_async_register_subdev(&state->sd);
+	if (ret) {
+		/* asd is freed during v4l2_async_notifier_cleanup() */
+		v4l2_async_notifier_unregister(&state->notifier);
+		v4l2_async_notifier_cleanup(&state->notifier);
+	}
+
+	return ret;
+
+err:
+	fwnode_handle_put(ep);
+	kfree(asd);
+
+	return ret;
 }
 
 static const char * const tc358764_test_pattern_menu[] = {
@@ -1776,7 +1807,7 @@ static int tc358746_probe(struct i2c_client *client)
 	tc358746_set_pll(sd);
 	tc358746_enable_stream(sd, 0);
 
-	err = tc358746_async_register(sd);
+	err = tc358746_async_register(state);
 	if (err < 0)
 		goto err_mutex;
 
-- 
2.25.1

