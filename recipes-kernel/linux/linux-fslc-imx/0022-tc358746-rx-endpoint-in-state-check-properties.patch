From 7c8b4f0d591c75e6bf8759cdc65709234496f282 Mon Sep 17 00:00:00 2001
From: Rouven Czerwinski <r.czerwinski@pengutronix.de>
Date: Mon, 6 Dec 2021 10:15:22 +0100
Subject: [PATCH 22/25] tc358746: rx endpoint in state & check properties

Store the parallel receive endpoint in the state struct and parse the
VSYNC/HSYNC flags. If they are not explicitly set, print out and return
an error.

Signed-off-by: Rouven Czerwinski <r.czerwinski@pengutronix.de>
Signed-off-by: ian.dannapel <ian.dannapel@iris-sensing.com>
---
 drivers/media/i2c/tc358746.c | 18 ++++++++++++++----
 1 file changed, 14 insertions(+), 4 deletions(-)

diff --git a/drivers/media/i2c/tc358746.c b/drivers/media/i2c/tc358746.c
index dee5003482f1..9a46f66f24de 100644
--- a/drivers/media/i2c/tc358746.c
+++ b/drivers/media/i2c/tc358746.c
@@ -129,6 +129,7 @@ struct tc358746_state {
 	struct tc358746_csi_param *link_freq_settings;
 	u64			  *link_frequencies;
 	unsigned int		   link_frequencies_num;
+	struct v4l2_fwnode_endpoint rx;
 
 	/*
 	 * Parallel input
@@ -1695,11 +1696,9 @@ static const struct v4l2_async_notifier_operations tc358746_notify_ops = {
 
 static int tc358746_async_register(struct tc358746_state *state)
 {
-	struct v4l2_fwnode_endpoint vep = {
-		.bus_type = V4L2_MBUS_PARALLEL,
-	};
 	struct v4l2_async_subdev *asd = NULL;
 	struct fwnode_handle *ep;
+	struct v4l2_fwnode_bus_parallel *bus;
 	int ret;
 
 	v4l2_async_notifier_init(&state->notifier);
@@ -1708,10 +1707,20 @@ static int tc358746_async_register(struct tc358746_state *state)
 	if (!ep)
 		return -ENOTCONN;
 
-	ret = v4l2_fwnode_endpoint_parse(ep, &vep);
+	state->rx.bus_type = V4L2_MBUS_PARALLEL;
+	ret = v4l2_fwnode_endpoint_alloc_parse(ep, &state->rx);
 	if (ret)
 		goto err;
 
+	bus = &state->rx.bus.parallel;
+
+	if(!(bus->flags & (V4L2_MBUS_VSYNC_ACTIVE_HIGH | V4L2_MBUS_VSYNC_ACTIVE_LOW
+			   | V4L2_MBUS_HSYNC_ACTIVE_HIGH | V4L2_MBUS_HSYNC_ACTIVE_LOW))) {
+		v4l2_err(&state->sd, "Missing hsync/vsync configuration for parallel endpoint");
+		ret = -EINVAL;
+		goto err;
+	}
+
 	asd = kzalloc(sizeof(*asd), GFP_KERNEL);
 	if (!asd) {
 		ret = -ENOMEM;
@@ -1856,6 +1865,7 @@ static int tc358746_remove(struct i2c_client *client)
 	mutex_destroy(&state->confctl_mutex);
 	media_entity_cleanup(&sd->entity);
 	v4l2_ctrl_handler_free(&state->hdl);
+	v4l2_fwnode_endpoint_free(&state->rx);
 
 	return 0;
 }
-- 
