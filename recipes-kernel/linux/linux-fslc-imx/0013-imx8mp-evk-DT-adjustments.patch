From 73aadf0145fb105ffb40fabe8ff1ada64edc83f1 Mon Sep 17 00:00:00 2001
From: Rouven Czerwinski <r.czerwinski@pengutronix.de>
Date: Wed, 17 Nov 2021 15:40:32 +0100
Subject: [PATCH 13/25] imx8mp-evk: DT adjustments
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Sink and source ports for the bridge were inverted.

imx8mp-evk: fix data-lanes property for CSI interface

The downstream driver really does not respect any of the upstream
properties, expecting exactly one number to define the data-lanes
property instead of the usual data-lanes=<1 2 3…>.

The serializer datasheet send to us by iris has to resistors which
either connect the refclk to the pixel clock (24Mhz) or an on serializer
oscillator which has 32Mhz. Trial and error reveals that the 32Mhz
oscillator is connected to the tc358746, since only with this refclk the
tc358746 calculates the correct settings for the CSI TX inteface.

Signed-off-by: Rouven Czerwinski <r.czerwinski@pengutronix.de>
Signed-off-by: ian.dannapel <ian.dannapel@iris-sensing.com>
---
 arch/arm64/boot/dts/freescale/imx8mp-evk.dts | 78 ++++++++------------
 1 file changed, 32 insertions(+), 46 deletions(-)

diff --git a/arch/arm64/boot/dts/freescale/imx8mp-evk.dts b/arch/arm64/boot/dts/freescale/imx8mp-evk.dts
index aeabc7cbb345..5ccf5d89cee0 100644
--- a/arch/arm64/boot/dts/freescale/imx8mp-evk.dts
+++ b/arch/arm64/boot/dts/freescale/imx8mp-evk.dts
@@ -183,8 +183,8 @@
 	clk_serialize: clock_serialize {
 		compatible = "fixed-clock";
 		#clock-cells = <0>;
-		clock-frequency = <24000000>;
-		clock-output-names = "24m_serialize";
+		clock-frequency = <32000000>;
+		clock-output-names = "32m_serialize";
 	};
 };
 
@@ -499,16 +499,27 @@
 		pinctrl-names = "default";
 		pinctrl-0 = <&pinctrl_csi0_rst>;
 		reset-gpios = <&gpio1 6 GPIO_ACTIVE_LOW>;
-		port {
-			epc660_mipi1_ep: endpoint {
-				bus-type = <1>;
-				remote-endpoint = <&tc358748_ep0>;
+
+		#address-cells = <1>;
+		#size-cells = <0>;
+
+		port@0 {
+			reg = <0>;
+			epc660_parallel_out: endpoint {
+				bus-type = <5>;
+				bus-width = <12>;
+				hsync-active = <0>;
+				vsync-active = <0>;
+				field-even-active = <0>;
+				pclk-sample = <1>;
+				remote-endpoint = <&tc358748_parallel_in>;
 			};
 		};
 	};
-	tc358748_adapter: tc358748_adapter@e {
+
+	tc358748_adapter: csi-bridge@e {
 		compatible = "toshiba,tc358746";
-		reg = <0xE>;
+		reg = <0x0e>;
 		status = "okay";
 		
 		clocks = <&clk_serialize>;
@@ -516,22 +527,24 @@
 		
 		#address-cells = <1>;
 		#size-cells = <0>;
-		
+
 		port@0 {
 			reg = <0>;
-			tc358748_ep0: endpoint {
+			tc358748_parallel_in: endpoint {
 				bus-type = <5>;
 				bus-width = <12>;
-				remote-endpoint = <&epc660_mipi1_ep>;
+				hsync-active = <0>;
+				vsync-active = <0>;
+				field-even-active = <0>;
+				remote-endpoint = <&epc660_parallel_out>;
 			};
 		};
 		port@1 {
 			reg = <1>;
-			tc358748_ep1: endpoint {
-				data-lanes = <2>;
-				clock-lanes = <1>;
+			tc358748_mipi_out: endpoint {
+				data-lanes = <1 2>;
 				link-frequencies = /bits/ 64 <216000000>;
-				remote-endpoint = <&mipi1_sensor_ep>;
+				remote-endpoint = <&mipi1_csi_in>;
 			};
 		};
 	};
@@ -544,13 +557,14 @@
 
 	port@0 {
 		reg = <0>;
-		mipi1_sensor_ep: endpoint {
+		mipi1_csi_in: endpoint {
 			data-lanes = <2>;
 			clock-lanes = <1>;
-			remote-endpoint = <&tc358748_ep1>;
+			remote-endpoint = <&tc358748_mipi_out>;
 			csis-hs-settle = <3>;
 			csis-clk-settle = <0>;
 			csis-wclk;
+			link-frequencies = /bits/ 64 <216000000>;
 		};
 	};
 };
@@ -568,33 +582,6 @@
 		#gpio-cells = <2>;
 	};
 
-	ov5640_1: ov5640_mipi@3c {
-		compatible = "ovti,ov5640";
-		reg = <0x3c>;
-		pinctrl-names = "default";
-		pinctrl-0 = <&pinctrl_csi0_pwn>, <&pinctrl_csi0_rst>;
-		clocks = <&clk IMX8MP_CLK_IPP_DO_CLKO2>;
-		clock-names = "xclk";
-		assigned-clocks = <&clk IMX8MP_CLK_IPP_DO_CLKO2>;
-		assigned-clock-parents = <&clk IMX8MP_CLK_24M>;
-		assigned-clock-rates = <24000000>;
-		csi_id = <0>;
-		powerdown-gpios = <&gpio4 1 GPIO_ACTIVE_HIGH>;
-		reset-gpios = <&gpio4 0 GPIO_ACTIVE_LOW>;
-		mclk = <24000000>;
-		mclk_source = <0>;
-		mipi_csi;
-		status = "disabled";
-
-		port {
-			ov5640_mipi_1_ep: endpoint {
-				remote-endpoint = <&mipi_csi1_ep>;
-				data-lanes = <1 2>;
-				clock-lanes = <0>;
-			};
-		};
-	};
-
 	codec: wm8960@1a {
 		compatible = "wlf,wm8960";
 		reg = <0x1a>;
@@ -1275,8 +1262,7 @@
 	port@1 {
 		reg = <1>;
 		mipi_csi1_ep: endpoint {
-			remote-endpoint = <&ov5640_mipi_1_ep>;
-			data-lanes = <2>;
+			data-lanes = <1 2>;
 			csis-hs-settle = <13>;
 			csis-clk-settle = <2>;
 			csis-wclk;
-- 
2.25.1

