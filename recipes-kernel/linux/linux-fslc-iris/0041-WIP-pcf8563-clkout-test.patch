From f65402c41db82dca022a19a2dda7ceb4bfaf31ab Mon Sep 17 00:00:00 2001
From: Erik Schumacher <erik.schumacher@iris-sensing.com>
Date: Tue, 29 Nov 2022 16:50:00 +0100
Subject: [PATCH] WIP: pcf8563 clkout test

---
 drivers/rtc/rtc-pcf8563.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/drivers/rtc/rtc-pcf8563.c b/drivers/rtc/rtc-pcf8563.c
index b76f795a50b7..1a0b06b10cf5 100644
--- a/drivers/rtc/rtc-pcf8563.c
+++ b/drivers/rtc/rtc-pcf8563.c
@@ -11,6 +11,8 @@
  * http://www.semiconductors.philips.com/acrobat/datasheets/PCF8563-04.pdf
  */
 
+#define DEBUG
+
 #include <linux/clk-provider.h>
 #include <linux/i2c.h>
 #include <linux/bcd.h>
@@ -612,6 +614,14 @@ static int pcf8563_probe(struct i2c_client *client,
 	/* register clk in common clk framework */
 	if(!of_property_read_bool(client->dev.of_node, "skip-register-clkout")) {
 		pcf8563_clkout_register_clk(pcf8563);
+	} else {
+		// disable clkout
+		buf = 0;
+		err = pcf8563_write_block_data(client, PCF8563_REG_CLKO, 1, &buf);
+		if (err < 0) {
+			dev_err(&client->dev, "%s: write error\n", __func__);
+			return err;
+		}
 	}
 #endif
 
